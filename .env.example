# ─────────────────────────────────────────────
# Copie este arquivo para .env e preencha
# NUNCA suba o .env para o GitHub / Render Git
# Use as variáveis de ambiente do painel Render
# ─────────────────────────────────────────────

# Banco de dados PostgreSQL
# Use o Neon (neon.tech) — gratuito e não expira
# Cole a connection string que o Neon fornece
DATABASE_URL=postgresql://usuario:senha@host/banco?sslmode=require

# URL pública do site no Render (sem barra no final)
BASE_URL=https://seu-app.onrender.com

# Seu WhatsApp (DDD + número, sem +55, sem espaço)
WPP_ADMIN=11999999999

# Mercado Pago — Access Token
# Painel MP > Suas integrações > Credenciais
MP_ACCESS_TOKEN=APP_USR-0000000000000000-000000-00000000000000000000000000000000-000000000

# Melhor Envios — Token de acesso
# app.melhorenvio.com.br > Tokens > Gerar token
ME_TOKEN=eyJ0eXAiOiJKV1QiLCJhbGciOiJSUzI1NiJ9...

# CEP de origem (seu CEP, só números)
CEP_ORIGEM=01310100

# Dados do remetente para gerar etiqueta
ME_NOME=Minha Loja
ME_EMAIL=contato@minhaloja.com.br
ME_TELEFONE=11999999999
ME_CPF=00000000000
ME_NUMERO=100

# Dimensões padrão da embalagem (usadas no cálculo de frete)
PKG_ALTURA=10
PKG_LARGURA=20
PKG_COMP=30
PKG_PESO=0.5
